{
  "name": "cerca-trova-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Telegram bot for creator operations, reports, payments and document workflow.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed": "prisma db seed",
    "reconcile:known-users": "tsx src/scripts/reconcile-known-users.ts",
    "seed:teamleads": "tsx src/scripts/seed-teamleads.ts",
    "teamleads:audit": "tsx src/scripts/audit-teamlead-links.ts",
    "teamleads:reassign": "tsx src/scripts/reassign-teamlead-creators.ts",
    "teamleads:restore-previous": "tsx src/scripts/audit-teamlead-links.ts --restore-previous",
    "payments:audit": "tsx src/scripts/audit-payment-documents.ts",
    "stats:audit": "tsx src/scripts/audit-statistics-readiness.ts",
    "documents:june-audit": "tsx src/scripts/audit-june-document-readiness.ts",
    "documents:smoke-test": "tsx src/scripts/document-pipeline-smoke-test.ts",
    "contracts:import-signed": "tsx src/scripts/import-signed-contracts.ts",
    "grant:creator": "tsx src/scripts/grant-creator-access.ts",
    "grant:teamlead-creators": "tsx src/scripts/grant-teamlead-creator-access.ts",
    "grant:admin": "tsx src/scripts/grant-admin.ts",
    "reset:test-creator": "tsx src/scripts/reset-test-creator.ts",
    "templates:import-google-docs": "tsx src/scripts/docx-template-maintenance.ts import-google-docs",
    "templates:refresh-manifest": "tsx src/scripts/docx-template-maintenance.ts refresh-manifest",
    "templates:validate": "tsx src/scripts/docx-template-maintenance.ts validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "prisma": {
    "seed": "tsx src/scripts/reconcile-known-users.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "adm-zip": "^0.5.17",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "googleapis": "^171.4.0",
    "handlebars": "^4.7.8",
    "mammoth": "^1.12.0",
    "node-cron": "^4.2.1",
    "pdf-parse": "^1.1.1",
    "pino": "^9.4.0",
    "playwright": "^1.53.0",
    "telegraf": "^4.16.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.10.2",
    "@types/pdf-parse": "^1.1.5",
    "pino-pretty": "^13.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
