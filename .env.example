# Core
BOT_TOKEN=1234567890:replace_with_real_telegram_bot_token
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cerca_trova_bot?schema=public
APP_ENV=development
LOG_LEVEL=info
TZ=Europe/Moscow

# Bootstrap access
ADMIN_TELEGRAM_IDS=

# Temporary weekend creator invite. Disable with TEMP_CREATOR_INVITE_ENABLED=false.
TEMP_CREATOR_INVITE_ENABLED=true
TEMP_CREATOR_INVITE_PAYLOAD=creator_weekend_2026
TEMP_CREATOR_INVITE_EXPIRES_AT=2026-05-04T00:00:00+03:00

# Cron schedules
DAILY_REMINDER_CRON=0 21 * * 1-6
DAILY_MISSED_CHECK_CRON=0 22 * * 1-6
WEEKLY_STATS_CRON=0 10 * * 1
WEEKLY_STATS_REMINDER_CRON=0 12,15,18,20 * * 1
WEEKLY_STATS_TEAMLEAD_REPORT_CRON=0 21 * * 1
DOCUMENT_RECEIPT_REMINDER_CRON=0 * * * *
GOOGLE_SHEETS_NIGHTLY_SYNC_CRON=

# Documents and storage
DOCUMENTS_CHAT_ID=-1003965254308
# Set DOCUMENTS_CHAT_TARGET=test to send document exports to TEST_DOCUMENTS_CHAT_ID.
TEST_DOCUMENTS_CHAT_ID=
DOCUMENTS_CHAT_TARGET=production
STORAGE_ROOT=./storage

# Google Sheets
GOOGLE_SHEETS_SYNC_ENABLED=false
# Можно указать чистый spreadsheetId или полную ссылку вида
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit#gid=0
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_STATS_SHEET_NAME=Статистика
GOOGLE_SHEETS_PAYMENTS_SHEET_NAME=Выплаты
GOOGLE_SHEETS_DOCUMENTS_SHEET_NAME=Документы
GOOGLE_SHEETS_BATCH_SIZE=500

# Google auth: option 1, файл ключа не коммитить в репозиторий
GOOGLE_APPLICATION_CREDENTIALS=

# Google auth: option 2, ключ хранить только в env/secret manager
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# PDF generation
PDF_FONT_FAMILY=DejaVu Sans
PDF_BROWSER_TIMEOUT_MS=30000
PDF_HEADLESS=true
PDF_EXECUTABLE_PATH=
# Use this when soffice/libreoffice is not in PATH.
LIBREOFFICE_EXECUTABLE_PATH=
# Keep this empty/false for normal document generation.
# HTML fallback is only for local diagnostics and does not preserve DOCX layout exactly.
DOCX_PDF_HTML_FALLBACK_ENABLED=

# Optional one-time template import from Google Docs.
# Runtime does not use these links; npm run templates:import-google-docs exports DOCX locally.
DOC_TEMPLATE_SOURCES_FILE=src/templates/documents-docx/sources.local.json
DOC_TEMPLATE_PACKAGE_SELF_EMPLOYED=
DOC_TEMPLATE_PACKAGE_IP=
DOC_TEMPLATE_NDA_EXAMPLE=
DOC_TEMPLATE_NDA_SELF_EMPLOYED=
DOC_TEMPLATE_NDA_IP=

# Business rules
MAX_MONTHLY_VIDEO_EDIT_DAY=10
# Optional emergency override. Leave empty for automatic close-window logic.
DOCUMENT_WORKFLOW_MONTH_KEY=
# Optional temporary override for newly generated contract/NDA dates.
# Use 2026-05-01 or 2026-06-01 only while admins intentionally choose that batch date.
DOCUMENT_CONTRACT_DATE=

# Company details for generated documents
COMPANY_NAME=ООО "Компания"
COMPANY_SHORT_NAME=ООО "Компания"
COMPANY_REPRESENTATIVE=Иван Иванов
COMPANY_REPRESENTATIVE_BASIS=действующего на основании устава
COMPANY_ADDRESS=Москва, ул. Пример, д. 1
COMPANY_INN=7700000000
COMPANY_BANK_NAME=АО "Банк"
COMPANY_BANK_ACCOUNT=40702810000000000000
COMPANY_BANK_BIK=044525000
COMPANY_BANK_CORR_ACCOUNT=30101810000000000000
COMPANY_EMAIL=docs@example.com
