<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <title>{{title}}</title>
    <style>
      body {
        font-family: "{{fontFamily}}", "DejaVu Sans", Arial, sans-serif;
        font-size: 12px;
        line-height: 1.5;
        color: #111827;
      }

      h1, h2, h3 {
        margin: 0 0 12px;
      }

      h1 {
        font-size: 18px;
        text-align: center;
        margin-bottom: 20px;
      }

      h2 {
        font-size: 14px;
        margin-top: 20px;
      }

      p {
        margin: 0 0 10px;
      }

      .muted {
        color: #4b5563;
      }

      .section {
        margin-top: 18px;
      }

      .block {
        border: 1px solid #d1d5db;
        padding: 12px;
        border-radius: 8px;
        margin-top: 12px;
      }

      .grid {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
      }

      .grid th,
      .grid td {
        border: 1px solid #d1d5db;
        padding: 6px 8px;
        vertical-align: top;
      }

      .signatures {
        margin-top: 30px;
        display: table;
        width: 100%;
      }

      .signatures > div {
        display: table-cell;
        width: 50%;
        vertical-align: top;
      }

      .signature-line {
        margin-top: 40px;
        border-top: 1px solid #111827;
        width: 80%;
        padding-top: 6px;
      }

      .small {
        font-size: 10px;
      }
    </style>
  </head>
  <body>
    {{{body}}}
  </body>
</html>
